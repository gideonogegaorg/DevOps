{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject"],
      "Resource": [
        "arn:aws:s3:::gideonogega-internal/familytree/prod/*",
        "arn:aws:s3:::gideonogega-internal/familytree/dev/*"
      ]
    },
    {
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": "arn:aws:s3:::gideonogega-internal",
      "Condition": {
        "StringLike": {
          "s3:prefix": ["familytree/prod/*", "familytree/dev/*"]
        }
      }
    }
  ]
}
