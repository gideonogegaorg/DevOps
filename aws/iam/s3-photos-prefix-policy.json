{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PhotosObjectAccess",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject"],
      "Resource": "arn:aws:s3:::BUCKET_NAME/APP_PREFIX/ENV_PREFIX/*"
    },
    {
      "Sid": "PhotosListPrefix",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": "arn:aws:s3:::BUCKET_NAME",
      "Condition": {
        "StringLike": {
          "s3:prefix": ["APP_PREFIX/ENV_PREFIX/*"]
        }
      }
    }
  ]
}
